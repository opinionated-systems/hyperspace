# hyperagents - API keys for LLM experiments
#
# Copy this file to .env and fill in your keys.
# The core module and unit tests do not require any API keys.
# Keys are only needed to run the LLM-driven experiments.

# Primary provider: Fireworks (checked first)
FIREWORKS_API_TOKEN=

# Alternative provider: OpenAI (used if no Fireworks key is set)
# OPENAI_API_KEY=

# Alternative provider: Google Gemini (OpenAI-compatible endpoint)
# GEMINI_API_KEY=

# Alternative provider: Anthropic Claude (OpenAI-compatible endpoint)
# ANTHROPIC_API_KEY=

# Alternative provider: Inception Labs (mercury-2, diffusion-based LLM)
# Very fast, very cheap — good for high-seed-count experiments
# INCEPTION_API_KEY=

OPENROUTER_API_KEY=
